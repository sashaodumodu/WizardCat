  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5c36fcf7f0f41a14ead69de23e8fe2f9, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NewMonoBehaviourScript
  textComponent: {fileID: 108031985}
  lines:
  - Hey there Wizard Cat!
  - I'm sick... Please, help me!
  - You can make a healing potion, right?
  - I know you need some sort of base, so I have water here for you.
  - And, I think there's a heartfruit in the trees!
  - You know what to do right? Your cauldron's at home or something... hurry, please!
  - Come back when you have a potion for me please! You can drop it near me when
    you have it.
  textSpeed: 0
